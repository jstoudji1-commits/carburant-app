function deplacerMarqueurUtilisateur(
    nouvelleLatitude,
    nouvelleLongitude
) {

    if (animationPositionUtilisateur) {

        cancelAnimationFrame(
            animationPositionUtilisateur
        );

    }

    var depart = marqueurUtilisateur.getLatLng();
    var latitudeDepart = depart.lat;
    var longitudeDepart = depart.lng;
    var debutAnimation = performance.now();
    var dureeAnimation = 900;

    function animerPosition(tempsActuel) {

        var progression = Math.min(
            (tempsActuel - debutAnimation) / dureeAnimation,
            1
        );

        var progressionAdoucie =
            progression * (2 - progression);

        var latitudeActuelle =
            latitudeDepart
            + (nouvelleLatitude - latitudeDepart)
            * progressionAdoucie;

        var longitudeActuelle =
            longitudeDepart
            + (nouvelleLongitude - longitudeDepart)
            * progressionAdoucie;

        marqueurUtilisateur.setLatLng([
            latitudeActuelle,
            longitudeActuelle
        ]);

        if (suiviCarteActif) {
            appliquerMouvementCarteAutomatique(
                function() {
                    map.panTo(
                        [
                            latitudeActuelle,
                            longitudeActuelle
                        ],
                        {
                            animate: false
                        }
                    );
                }
            );
        }

        if (progression < 1) {

            animationPositionUtilisateur =
                requestAnimationFrame(
                    animerPosition
                );

        }

    }

    animationPositionUtilisateur =
        requestAnimationFrame(
            animerPosition
        );

}

function distanceDeplacementKm(
    latitudeDepart,
    longitudeDepart,
    latitudeArrivee,
    longitudeArrivee
) {

    var rayonTerre = 6371;
    var conversion = Math.PI / 180;
    var dLatitude = (
        latitudeArrivee - latitudeDepart
    ) * conversion;
    var dLongitude = (
        longitudeArrivee - longitudeDepart
    ) * conversion;

    latitudeDepart *= conversion;
    latitudeArrivee *= conversion;

    var a =
        Math.sin(dLatitude / 2) ** 2
        + Math.cos(latitudeDepart)
        * Math.cos(latitudeArrivee)
        * Math.sin(dLongitude / 2) ** 2;

    return rayonTerre * 2 * Math.atan2(
        Math.sqrt(a),
        Math.sqrt(1 - a)
    );

}

function actualiserStationsSelonPosition() {

    if (actualisationStationsEnCours) {

        return;

    }

    if (navigationActive) {
        return;
    }

    var positionInitialeManquante =
        Number.isNaN(latitudeDerniereRecherche)
        || Number.isNaN(longitudeDerniereRecherche);

    var distanceParcourue = positionInitialeManquante
        ? distanceActualisationKm
        : distanceDeplacementKm(
            latitudeDerniereRecherche,
            longitudeDerniereRecherche,
            latitudeUtilisateur,
            longitudeUtilisateur
        );

    var maintenant = Date.now();
    var delaiRespecte =
        positionInitialeManquante
        || maintenant - derniereActualisationStations
            >= delaiActualisationMs;

    if (
        distanceParcourue < distanceActualisationKm
        || !delaiRespecte
    ) {

        return;

    }

    var formulaire = document.querySelector(
        "form.control-card"
    );

    if (!formulaire) {

        return;

    }

    actualisationStationsEnCours = true;
    derniereActualisationStations = maintenant;
