function proposerStationPlusRentablePendantNavigation(
    meilleureStation,
    stationsCalculees,
    economieInstantanee
) {

    if (
        !comptePremiumActif()
        || !navigationActive
        || !stationNavigationActive
        || !meilleureStation
        || memeStation(meilleureStation, stationNavigationActive)
    ) {
        return;
    }

    var stationCourante = stationsCalculees.find(
        function(station) {
            return memeStation(station, stationNavigationActive);
        }
    );

    if (!stationCourante) {
        return;
    }

    var economieSupplementaire =
        stationCourante.coutTotal - meilleureStation.coutTotal;

    if (
        !Number.isFinite(economieSupplementaire)
        || economieSupplementaire < 0.50
    ) {
        return;
    }

    if (
        propositionStationIgnoreeId
        && String(meilleureStation.id || "") === propositionStationIgnoreeId
        && Date.now() - propositionStationIgnoreeDepuis < 5 * 60 * 1000
    ) {
        return;
    }

    propositionStationPlusRentable = {
        station: meilleureStation,
        economie: economieInstantanee,
        economieSupplementaire: economieSupplementaire
    };

    var popup = document.getElementById("better-station-popup");
    var texte = document.getElementById("better-station-copy");

    if (!popup || !texte) {
        return;
    }

    texte.textContent =
        (meilleureStation.enseigne || "Une station")
        + (meilleureStation.ville ? " \u00e0 " + meilleureStation.ville : "")
        + " devient plus rentable : +"
        + economieSupplementaire.toLocaleString(
            "fr-FR",
            {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }
        )
        + " \u20ac estim\u00e9s par rapport \u00e0 l'itin\u00e9raire actuel.";
