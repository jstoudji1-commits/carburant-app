var inclinaisonCarteGps = 58;
var capCarte = capInitialCarte;
var dernierCapUtilisateur = (360 - capInitialCarte) % 360;
var capFlecheUtilisateur = dernierCapUtilisateur;
var dateDernierCapFiable = 0;
var utilisateurEnMouvement = false;
var vitesseUtilisateurMps = 0;
var precisionUtilisateur = 20;
