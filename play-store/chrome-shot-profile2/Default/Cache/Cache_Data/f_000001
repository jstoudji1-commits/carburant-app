<script>

var dateDerniereMiseAJour = new Date("2026-06-24T14:18:28.674154+00:00");
var dateDonneesChargees = dateDerniereMiseAJour
    ? dateDerniereMiseAJour.toISOString()
    : "";
var rechargementPrixEnCours = false;
var derniereSynchronisationPrix = 0;

function texteAgeMiseAJour() {

    if (!dateDerniereMiseAJour || Number.isNaN(dateDerniereMiseAJour.getTime())) {
        return "v\u00e9rification en attente";
    }

    var secondes = Math.max(
        0,
        Math.floor((Date.now() - dateDerniereMiseAJour.getTime()) / 1000)
    );

    if (secondes < 60) {
        return "v\u00e9rifi\u00e9 il y a "
            + secondes
            + (secondes === 1 ? " seconde" : " secondes");
    }

    var minutes = Math.floor(secondes / 60);
    return "v\u00e9rifi\u00e9 il y a "
        + minutes
        + (minutes === 1 ? " minute" : " minutes");

}

function actualiserCompteurMiseAJour() {

    var texteActualise = texteAgeMiseAJour();
    var compteur = document.getElementById("update-age");
    if (compteur) {
        compteur.textContent = texteActualise;
    }

    document.querySelectorAll(
        ".station-update-age"
    ).forEach(
        function(compteurStation) {
            compteurStation.textContent = texteActualise;
        }
    );

}

function rechargerAvecPositionActuelle() {

    if (rechargementPrixEnCours) {
        return;
    }

    rechargementPrixEnCours = true;

    var url = new URL(window.location.href);
    if (
        latitudeUtilisateur !== null
        && longitudeUtilisateur !== null
    ) {
        url.searchParams.set("latitude", latitudeUtilisateur);
        url.searchParams.set("longitude", longitudeUtilisateur);
    }
    url.searchParams.set("carburant", "sp98");
    url.searchParams.set("rayon", "15");

    sessionStorage.setItem(
        "optiplein-cap-carte",
        String(capCarte)
    );
    window.location.replace(url.toString());

}

async function synchroniserDateMiseAJour() {

    try {
        var reponse = await fetch(
            "/api/derniere-mise-a-jour",
            { cache: "no-store" }
        );
        if (!reponse.ok) {
            return;
        }

        var donnees = await reponse.json();
        if (donnees.updated_at) {
            var dateServeur = new Date(donnees.updated_at);
            if (Number.isNaN(dateServeur.getTime())) {
                return;
            }
            var isoServeur = dateServeur.toISOString();
            dateDerniereMiseAJour = dateServeur;
            actualiserCompteurMiseAJour();

            if (
                dateDonneesChargees
                && isoServeur !== dateDonneesChargees
            ) {
                afficherInfoItineraire(
                    "Nouveaux prix disponibles, actualisation..."
                );
                rechargerAvecPositionActuelle();
            }
        }
    } catch (erreur) {
        console.log("Synchronisation de la mise a jour indisponible");
    }

}

actualiserCompteurMiseAJour();
setInterval(actualiserCompteurMiseAJour, 1000);

function intervalleSynchronisationPrixMs() {

    return comptePremiumActif()
        ? 30 * 1000
        : 3 * 60 * 1000;

}

setInterval(
    function() {
        var maintenant = Date.now();
        if (
            maintenant - derniereSynchronisationPrix
                < intervalleSynchronisationPrixMs()
        ) {
            return;
        }

        derniereSynchronisationPrix = maintenant;
        synchroniserDateMiseAJour();
    },
    30000
);

window.ouvrirSignalement = function() {

    var fenetre = document.getElementById("problem-modal");
    var statut = document.getElementById("problem-status");

    if (!fenetre) {
        return;
    }

    if (statut) {
        statut.textContent = "";
        statut.className = "problem-status";
    }

    fenetre.hidden = false;
    document.getElementById("problem-category").focus();

};

window.fermerSignalement = function() {

    var fenetre = document.getElementById("problem-modal");

    if (fenetre) {
        fenetre.hidden = true;
    }

};

window.fermerSignalementDepuisFond = function(event) {

    if (event.target === event.currentTarget) {
        fermerSignalement();
    }

};

window.envoyerSignalement = async function(event) {

    event.preventDefault();

    var formulaire = event.currentTarget;
    var bouton = document.getElementById("problem-submit");
    var statut = document.getElementById("problem-status");
    var donneesFormulaire = new FormData(formulaire);
    var donnees = Object.fromEntries(donneesFormulaire.entries());
    donnees.page = window.location.origin + window.location.pathname;

    bouton.disabled = true;
    bouton.textContent = "Envoi...";
    statut.textContent = "";
    statut.className = "problem-status";

    try {
        var reponse = await fetch(
            "/api/signaler-probleme",
            {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(donnees)
            }
        );
        var resultat = await reponse.json().catch(
            function() {
                return {};
            }
        );

        if (!reponse.ok) {
            throw new Error(
                resultat.detail
                || "Le message n'a pas pu etre envoye."
            );
        }

        formulaire.reset();
        statut.textContent = "Merci, votre signalement a bien ete envoye.";
        statut.className = "problem-status success";
    } catch (erreur) {
        statut.textContent = erreur.message;
        statut.className = "problem-status error";
    } finally {
        bouton.disabled = false;
        bouton.textContent = "Envoyer";
    }

};

document.addEventListener(
    "keydown",
    function(event) {
        if (event.key === "Escape") {
            fermerSignalement();
        }
    }
);

