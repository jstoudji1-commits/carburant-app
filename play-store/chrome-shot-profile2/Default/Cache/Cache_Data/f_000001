window.partagerPrixStation = async function(event, station) {

    if (event) {
        event.preventDefault();
        event.stopPropagation();
    }

    var prixNombre = Number(station.prix);
    var prixPartage = prixNombre === 0 || prixNombre === 9.999
        ? "indisponible"
        : prixNombre.toLocaleString(
            "fr-FR",
            {
                minimumFractionDigits: 3,
                maximumFractionDigits: 3
            }
        ) + " \u20ac";
    var texte =
        station.carburant
        + " \u00e0 "
        + prixPartage
        + " - "
        + station.adresse
        + ", "
        + station.cp
        + " "
        + station.ville;
    var url =
        window.location.origin
        + window.location.pathname
        + "?carburant="
        + encodeURIComponent(
            station.carburant.toLowerCase()
        );
    var donnees = {
        title: "Prix carburant OptiPlein",
        text: texte,
        url: url
    };

    if (navigator.share) {

        try {
            await navigator.share(donnees);
            return;
        } catch (erreur) {
            if (erreur.name === "AbortError") {
                return;
            }
        }

    }

    var contenu = texte + "\n" + url;

    try {
        await navigator.clipboard.writeText(contenu);
    } catch (erreur) {
        var zoneCopie = document.createElement("textarea");
        zoneCopie.value = contenu;
        zoneCopie.style.position = "fixed";
        zoneCopie.style.opacity = "0";
        document.body.appendChild(zoneCopie);
        zoneCopie.select();
        document.execCommand("copy");
        zoneCopie.remove();
    }

    var bouton = event && event.currentTarget;

    if (bouton) {
        var libelleInitial = bouton.textContent;
        bouton.textContent = "Copi\u00e9 !";
