<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Comparateur Carburant</title>
    <link rel="icon" type="image/png" href="/static/favicon.png">

<style>

:root{
    --green:#149f38;
    --green-dark:#087a2c;
    --green-soft:#e8f7ec;
    --ink:#102536;
    --muted:#657485;
    --line:#dce4ea;
    --panel:#ffffff;
    --shadow:0 12px 30px rgba(16,37,54,0.16);
}

*{
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    margin:0;
    background:#eef3ef;
    color:var(--ink);
    overflow:hidden;
}

.topbar{
    position:fixed;
    top:0;
    left:14px;
    right:14px;
    height:104px;
    z-index:1200;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:18px 28px;
    background:rgba(255,255,255,0.95);
    border:1px solid rgba(220,228,234,0.9);
    border-radius:0 0 14px 14px;
    box-shadow:var(--shadow);
    backdrop-filter:blur(8px);
}

.logo{
    height:72px;
    width:auto;
}

.top-actions{
    display:flex;
    align-items:center;
    gap:18px;
}

.vehicle-menu{
    position:relative;
}

.vehicle-button{
    max-width:min(260px, 44vw);
    padding:16px 24px;
    background:linear-gradient(180deg, #27b33e, #087a2c);
    color:white;
    border:none;
    border-radius:9px;
    font-size:17px;
    font-weight:bold;
    cursor:pointer;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
    box-shadow:0 8px 18px rgba(8,122,44,0.25);
}

.vehicle-panel{
    position:absolute;
    top:calc(100% + 12px);
    right:0;
    width:340px;
    max-height:calc(100vh - 120px);
    overflow:auto;
    padding:18px;
    background:white;
    border:1px solid var(--line);
    border-radius:10px;
    box-shadow:var(--shadow);
}

.vehicle-panel[hidden]{
    display:none;
}

.vehicle-panel-title{
    margin:0 0 14px 0;
    font-size:17px;
}

.account-plan{
    display:grid;
    gap:10px;
    margin-bottom:14px;
    padding:12px;
    border:1px solid #dce4ea;
    border-radius:9px;
    background:#f7faf8;
}

.account-plan-label{
    margin:0;
    color:var(--muted);
    font-size:13px;
    font-weight:bold;
}

.account-plan-actions{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:8px;
}

.account-plan-button{
    padding:10px 8px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    background:white;
    color:var(--ink);
    font-weight:bold;
    cursor:pointer;
}

.account-plan-button.active{
    border-color:var(--green);
    background:#e8f7ec;
    color:var(--green-dark);
    box-shadow:0 0 0 2px rgba(20,159,56,0.12);
}

.account-sync{
    display:grid;
    gap:9px;
    margin-bottom:14px;
    padding:12px;
    border:1px solid #dce4ea;
    border-radius:9px;
    background:#ffffff;
}

.account-sync-title{
    margin:0;
    color:var(--ink);
    font-size:14px;
    font-weight:800;
}

.account-sync-copy{
    margin:0;
    color:var(--muted);
    font-size:12px;
    line-height:1.3;
}

.account-sync input{
    width:100%;
    padding:10px 11px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    color:var(--ink);
    font-size:14px;
}

.account-sync-actions{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:8px;
}

.account-sync-button{
    padding:10px 8px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    background:white;
    color:var(--ink);
    font-weight:bold;
    cursor:pointer;
}

.account-sync-button.primary{
    border-color:var(--green);
    background:var(--green);
    color:white;
}

.account-sync-button.logout{
    grid-column:1 / -1;
    color:#b42318;
}

.account-sync-button[hidden]{
    display:none;
}

.account-sync-status{
    min-height:17px;
    margin:0;
    color:var(--muted);
    font-size:12px;
    font-weight:bold;
}

.account-sync-status.success{
    color:var(--green-dark);
}

.account-sync-status.error{
    color:#b42318;
}

.vehicle-list{
    display:grid;
    gap:8px;
    margin-bottom:12px;
}

.vehicle-list[hidden]{
    display:none;
}

.vehicle-list-button{
    width:100%;
    padding:10px 12px;
    border:1px solid #dce4ea;
    border-radius:8px;
    background:white;
    color:var(--ink);
    font-weight:bold;
    text-align:left;
    cursor:pointer;
}

.vehicle-list-button.active{
    border-color:var(--green);
    background:#e8f7ec;
}

.premium-menu{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:7px;
    margin:12px 0;
}

.premium-menu[hidden]{
    display:none;
}

.premium-menu-button{
    padding:10px 6px;
    border:1px solid #dce4ea;
    border-radius:8px;
    background:#fff;
    color:var(--ink);
    font-size:12px;
    font-weight:800;
    cursor:pointer;
}

.premium-menu-button.active{
    border-color:var(--green);
    background:#e8f7ec;
    color:var(--green-dark);
}

.premium-page{
    display:none;
}

.premium-page.active{
    display:block;
}

.premium-panel-card{
    display:grid;
    gap:10px;
    margin:0 0 12px 0;
    padding:13px;
    border:1px solid #dce4ea;
    border-radius:10px;
    background:#fff;
}

.premium-panel-title{
    margin:0;
    color:var(--ink);
    font-size:14px;
    font-weight:800;
}

.premium-empty{
    margin:0;
    color:var(--muted);
    font-size:12px;
    line-height:1.35;
}

.premium-history-list{
    display:grid;
    gap:8px;
}

.premium-history-item{
    display:grid;
    gap:3px;
    padding:10px;
    border:1px solid #edf1f3;
    border-radius:8px;
    background:#f8fbf9;
}

.premium-history-main{
    display:flex;
    justify-content:space-between;
    gap:8px;
    color:var(--ink);
    font-size:13px;
    font-weight:800;
}

.premium-history-saving{
    color:var(--green-dark);
    white-space:nowrap;
}

.premium-history-meta,
.premium-option-copy{
    margin:0;
    color:var(--muted);
    font-size:12px;
    line-height:1.35;
}

.premium-option-button{
    width:100%;
    padding:11px 12px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    background:#fff;
    color:var(--green-dark);
    font-weight:800;
    cursor:pointer;
}

.premium-option-button.danger{
    color:#b42318;
}

.vehicle-secondary-button{
    width:100%;
    margin:0 0 12px 0;
    padding:11px 14px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    background:white;
    color:var(--green-dark);
    font-size:14px;
    font-weight:bold;
    cursor:pointer;
}

.vehicle-secondary-button[hidden]{
    display:none;
}

.vehicle-save-button{
    width:100%;
    margin-top:14px;
    padding:13px 16px;
    border:none;
    border-radius:8px;
    background:linear-gradient(180deg, #27b33e, #087a2c);
    color:white;
    font-size:15px;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 6px 14px rgba(8,122,44,0.22);
}

.app-layout{
    position:fixed;
    inset:104px 0 0 0;
    display:grid;
    grid-template-columns:395px 1fr;
    min-height:0;
}

.sidebar{
    z-index:900;
    display:flex;
    flex-direction:column;
    padding:24px 18px 18px 18px;
    overflow:auto;
    background:rgba(245,248,246,0.78);
    box-shadow:10px 0 24px rgba(16,37,54,0.10);
}

.stat-card{
    background:linear-gradient(145deg, #0b8d35 0%, #071f31 82%);
    color:white;
    border-radius:12px;
    padding:26px 26px 24px 26px;
    box-shadow:var(--shadow);
}

.stat-price-layout{
    display:grid;
    grid-template-columns:72px 1fr;
    gap:18px;
    align-items:center;
}

.stat-price-meta{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:8px;
}

.stat-icon{
    width:62px;
    height:62px;
    border-radius:14px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:rgba(255,255,255,0.14);
    color:white;
    font-size:13px;
    font-weight:bold;
    text-align:center;
}

.stat-label{
    margin:0 0 16px 0;
    font-size:18px;
    font-weight:bold;
    line-height:1.2;
    text-align:center;
    white-space:nowrap;
}

.stat-value{
    display:flex;
    align-items:flex-start;
    justify-content:center;
    width:100%;
    gap:4px;
    font-size:50px;
    line-height:0.95;
    font-weight:bold;
}

.stat-currency{
    margin-top:1px;
    font-size:24px;
    line-height:1;
    font-weight:bold;
}

.stat-value.indisponible{
    font-size:27px;
    line-height:1.1;
}

.best-price{
    color:#35ec68;
}

.stat-price-detail{
    min-width:0;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:11px;
}

.stat-station-min{
    min-width:0;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:7px;
    color:white;
    font-size:14px;
    line-height:1.2;
    text-align:center;
    padding:3px 5px;
    border:0;
    border-radius:6px;
    background:transparent;
    font-family:inherit;
    cursor:pointer;
    transition:background-color 160ms ease, transform 160ms ease;
}

.stat-station-min:hover,
.stat-station-min:focus-visible{
    background:rgba(255,255,255,0.13);
    outline:2px solid rgba(255,255,255,0.72);
    outline-offset:2px;
}

.stat-station-min:active{
    transform:scale(0.98);
}

.stat-station-min .enseigne-logo{
    width:23px;
    height:23px;
    border-radius:5px;
}

.stat-station-min strong{
    font-weight:800;
}

.price-pill{
    width:62px;
    padding:6px 4px;
    box-sizing:border-box;
    background:#159b31;
    color:white;
    border-radius:8px;
    font-size:13px;
    font-weight:bold;
    line-height:1.1;
    text-align:center;
}

.control-card,
.favoris-liste,
.update-card{
    margin-top:16px;
    padding:18px;
    background:rgba(255,255,255,0.96);
    border:1px solid rgba(220,228,234,0.95);
    border-radius:12px;
    box-shadow:0 8px 22px rgba(16,37,54,0.10);
}

.control-title{
    margin:0 0 14px 0;
    font-size:18px;
    font-weight:bold;
}

.carburant-boutons{
    display:grid;
    grid-template-columns:repeat(3, minmax(0, 1fr));
    gap:10px;
}

.carburant-boutons input{
    position:absolute;
    opacity:0;
    pointer-events:none;
}

.carburant-boutons label{
    min-height:86px;
    padding:11px 8px;
    border:1px solid #cbd5dd;
    border-radius:9px;
    background:white;
    color:var(--ink);
    font-weight:bold;
    text-align:center;
    cursor:pointer;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:8px;
    box-shadow:0 4px 11px rgba(16,37,54,0.08);
    transition:all 0.18s ease;
}

.fuel-dot{
    display:flex;
    align-items:center;
    justify-content:center;
    width:38px;
    height:38px;
    border-radius:50%;
    background:#0b8d35;
    color:white;
    font-size:17px;
    font-weight:bold;
}

.fuel-dot.blue{
    background:#1167e8;
}

.fuel-dot.dark{
    background:#102536;
}

.carburant-boutons input:checked + label{
    border-color:var(--green);
    box-shadow:0 0 0 2px rgba(20,159,56,0.20), 0 8px 18px rgba(16,37,54,0.14);
    transform:translateY(-1px);
}

.favoris-liste{
    display:none;
}

.favoris-liste.visible{
    display:block;
}

.favoris-titre{
    margin:0 0 8px 0;
    color:var(--ink);
    font-size:15px;
    font-weight:bold;
}

.favori-ligne{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    padding:9px 0;
    border-top:1px solid #edf2ef;
}

.favori-ligne:first-of-type{
    border-top:none;
}

.favori-nom{
    color:var(--ink);
    font-size:13px;
    line-height:1.3;
}

.favori-actions{
    display:flex;
    gap:6px;
    flex-shrink:0;
}

.favori-action{
    padding:8px 10px;
    background:#214053;
    color:white;
    border:none;
    border-radius:7px;
    font-weight:bold;
    cursor:pointer;
}

.favori-bouton{
    width:42px;
    height:42px;
    margin:0 auto 10px auto;
    padding:0;
    display:flex;
    align-items:center;
    justify-content:center;
    background:white;
    color:#d8a100;
    border:2px solid #d8a100;
    border-radius:50%;
    font-size:28px;
    line-height:1;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 5px 14px rgba(16,37,54,0.14);
}

.favori-bouton.actif{
    background:#fff4c7;
    color:#d8a100;
    border-color:#d8a100;
}

.favori-action.retirer{
    background:var(--green);
    color:white;
}

.popup-actions{
    display:grid;
    grid-template-columns:repeat(2, minmax(0, 1fr));
    gap:8px;
    width:100%;
    max-width:260px;
    margin:0 auto;
}

.popup-action{
    min-width:0;
    padding:9px 10px;
    border:1px solid transparent;
    border-radius:9px;
    color:white;
    font-size:13px;
    font-weight:bold;
    cursor:pointer;
    white-space:nowrap;
    box-shadow:0 5px 12px rgba(16,37,54,0.13);
}

.popup-action.route{
    background:#149f38;
}

.popup-action.share{
    background:#214053;
}

.popup-action.external{
    background:#ffffff;
    color:#173346;
    border-color:#d8e1e8;
}

.popup-action.external.waze{
    color:#099bd8;
}

.popup-action.external.google{
    color:#12813a;
}

.premium-navigation[hidden]{
    display:none;
}

.premium-only[hidden]{
    display:none;
}

.favoris-info{
    margin:0 0 10px 0;
    color:var(--muted);
    font-size:13px;
    font-weight:bold;
}

.update-card{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    color:#4f5f6c;
    font-size:14px;
}

.update-dot{
    position:relative;
    width:12px;
    height:12px;
    border-radius:50%;
    background:var(--green);
    flex:0 0 auto;
    box-shadow:0 0 0 0 rgba(20,159,56,0.38);
    animation:update-dot-pulse 2.2s ease-out infinite;
}

.update-dot::after{
    content:"";
    position:absolute;
    inset:3px;
    border-radius:50%;
    background:#5df07e;
    animation:update-dot-glow 2.2s ease-in-out infinite;
}

@keyframes update-dot-pulse{
    0%, 35%{
        box-shadow:0 0 0 0 rgba(20,159,56,0.38);
        transform:scale(1);
    }
    65%{
        box-shadow:0 0 0 8px rgba(20,159,56,0);
        transform:scale(1.08);
    }
    100%{
        box-shadow:0 0 0 0 rgba(20,159,56,0);
        transform:scale(1);
    }
}

@keyframes update-dot-glow{
    0%, 100%{
        opacity:0.55;
    }
    50%{
        opacity:1;
    }
}

@media (prefers-reduced-motion: reduce){
    .update-dot,
    .update-dot::after,
    .gps-position-arrow span{
        animation:none;
    }
}

.problem-report-link{
    align-self:center;
    margin-top:auto;
    padding-top:18px;
    border:none;
    background:transparent;
    color:#657485;
    font-size:13px;
    font-family:inherit;
    text-decoration:underline;
    text-underline-offset:3px;
    cursor:pointer;
}

.problem-report-link:hover,
.problem-report-link:focus-visible{
    color:var(--green-dark);
}

.problem-modal{
    position:fixed;
    inset:0;
    z-index:3000;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:18px;
    background:rgba(7,31,49,0.56);
}

.problem-modal[hidden]{
    display:none;
}

.problem-dialog{
    position:relative;
    width:min(520px, 100%);
    max-height:calc(100vh - 36px);
    overflow:auto;
    padding:24px;
    border-radius:10px;
    background:white;
    color:var(--ink);
    box-shadow:0 22px 60px rgba(7,31,49,0.30);
}

.problem-dialog h2{
    margin:0 42px 18px 0;
    font-size:22px;
}

.problem-close{
    position:absolute;
    top:14px;
    right:14px;
    width:34px;
    height:34px;
    padding:0;
    border:none;
    border-radius:8px;
    background:#edf2ef;
    color:var(--ink);
    font-size:23px;
    cursor:pointer;
}

.problem-form{
    display:grid;
    gap:14px;
}

.problem-field{
    display:grid;
    gap:6px;
}

.problem-field label{
    font-size:14px;
    font-weight:bold;
}

.problem-field input,
.problem-field select,
.problem-field textarea{
    width:100%;
    padding:11px 12px;
    border:1px solid #cbd5dd;
    border-radius:8px;
    background:white;
    color:var(--ink);
    font:inherit;
}

.problem-field textarea{
    min-height:120px;
    resize:vertical;
}

.problem-field input:focus,
.problem-field select:focus,
.problem-field textarea:focus{
    border-color:var(--green);
    outline:none;
    box-shadow:0 0 0 3px rgba(20,159,56,0.14);
}

.problem-honeypot{
    position:absolute;
    left:-10000px;
    width:1px;
    height:1px;
    overflow:hidden;
}

.problem-status{
    min-height:20px;
    margin:0;
    color:#526474;
    font-size:13px;
    font-weight:bold;
}

.problem-status.success{
    color:var(--green-dark);
}

.problem-status.error{
    color:#b42318;
}

.problem-actions{
    display:flex;
    justify-content:flex-end;
    gap:10px;
}

.problem-action{
    padding:11px 16px;
    border:none;
    border-radius:8px;
    font-size:14px;
    font-weight:bold;
    cursor:pointer;
}

.problem-action.cancel{
    background:#edf2ef;
    color:var(--ink);
}

.problem-action.send{
    background:var(--green);
    color:white;
}

.problem-action:disabled{
    opacity:0.6;
    cursor:wait;
}

.data-source-link{
    align-self:center;
    margin-top:8px;
    color:#7b8792;
    font-size:11px;
    text-decoration:none;
}

.data-source-link:hover,
.data-source-link:focus-visible{
    color:var(--green-dark);
    text-decoration:underline;
}

.vehicle-fields{
    display:grid;
    gap:10px;
}

.vehicle-input{
    width:100%;
    padding:13px 14px;
    border:1px solid #cbd5dd;
    border-radius:9px;
    background:white;
    color:var(--ink);
    font-size:15px;
    outline:none;
}

.vehicle-input:focus{
    border-color:var(--green);
    box-shadow:0 0 0 3px rgba(20,159,56,0.14);
}

.reservoir-gauge{
    display:grid;
    gap:8px;
    margin-top:2px;
    padding:12px;
    border:1px solid #dce4ea;
    border-radius:9px;
    background:#f7faf8;
}

.reservoir-gauge-header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    color:var(--ink);
    font-size:14px;
    font-weight:bold;
}

.reservoir-gauge-value{
    color:var(--green-dark);
}

.reservoir-gauge input[type="range"]{
    width:100%;
    accent-color:var(--green);
}

.premium-offer{
    margin:14px 0 0 0;
    padding:14px;
    border:1px solid rgba(20,159,56,0.22);
    border-radius:10px;
    background:linear-gradient(180deg, #f4fff7, #ffffff);
    color:var(--ink);
}

.premium-offer-title{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:10px;
    margin:0 0 8px 0;
    font-size:15px;
    font-weight:800;
}

.premium-price{
    flex:0 0 auto;
    color:var(--green-dark);
    font-size:16px;
    white-space:nowrap;
}

.premium-offer-copy{
    margin:0 0 10px 0;
    color:#425463;
