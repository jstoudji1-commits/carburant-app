function memeStation(stationA, stationB) {

    if (!stationA || !stationB) {
        return false;
    }

    if (stationA.id && stationB.id) {
        return String(stationA.id) === String(stationB.id);
    }

    return Math.abs(Number(stationA.latitude) - Number(stationB.latitude)) < 0.00001
        && Math.abs(Number(stationA.longitude) - Number(stationB.longitude)) < 0.00001;

}

function trouverStationParCoordonnees(latitude, longitude) {

    return stationsEconomie.find(
        function(station) {
            return Math.abs(Number(station.latitude) - Number(latitude)) < 0.00001
                && Math.abs(Number(station.longitude) - Number(longitude)) < 0.00001;
        }
    ) || null;

}

