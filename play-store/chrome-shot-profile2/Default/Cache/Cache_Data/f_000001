        return;
    }

    var stationsDisponibles = stationsEconomie.filter(
        function(station) {
            return station.prix > 0 && station.prix !== 9.999;
        }
    );

    if (!stationsDisponibles.length) {
        return;
    }

    niveauReservoir = Math.max(
        0,
        Math.min(100, Number.isFinite(niveauReservoir) ? niveauReservoir : 50)
    );
    var litresACompleter = reservoir * (100 - niveauReservoir) / 100;
    var resultatRentabilite = calculerRentabiliteStations(
        stationsDisponibles,
        latitudeCalcul,
        longitudeCalcul,
        reservoir,
