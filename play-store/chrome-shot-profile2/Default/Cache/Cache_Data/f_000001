function demarrerGeolocalisation() {

    if (suiviGeolocalisationId !== null) {

        return;

    }

    suiviGeolocalisationId =
        navigator.geolocation.watchPosition(

        function(position) {

            var latitudePrecedente = latitudeUtilisateur;
            var longitudePrecedente = longitudeUtilisateur;

            latitudeUtilisateur =
    position.coords.latitude;

            longitudeUtilisateur =
    position.coords.longitude;

            precisionUtilisateur = Number.isFinite(
                Number(position.coords.accuracy)
            )
                ? Number(position.coords.accuracy)
                : 20;
            var capGps = position.coords.heading === null
                ? Number.NaN
                : Number(position.coords.heading);
            var vitesseGps = position.coords.speed === null
                ? Number.NaN
                : Number(position.coords.speed);
            vitesseUtilisateurMps = Number.isFinite(vitesseGps)
                ? Math.max(0, vitesseGps)
                : vitesseUtilisateurMps;
            var distanceDepuisPositionPrecedente = (
                latitudePrecedente === null
                || longitudePrecedente === null
            )
                ? 0
                : distanceDeplacementKm(
                    latitudePrecedente,
                    longitudePrecedente,
                    latitudeUtilisateur,
                    longitudeUtilisateur
                );

            utilisateurEnMouvement =
                (Number.isFinite(vitesseGps) && vitesseGps >= 1)
                || distanceDepuisPositionPrecedente >= 0.003;

            var capDeplacement = distanceDepuisPositionPrecedente >= 0.003
                ? calculerCapDeplacement(
                    latitudePrecedente,
                    longitudePrecedente,
                    latitudeUtilisateur,
                    longitudeUtilisateur
                )
                : Number.NaN;
            var capMesure = Number.isFinite(capGps) && capGps >= 0
                ? capGps
                : capDeplacement;

            if (Number.isFinite(capMesure) && utilisateurEnMouvement) {
                var facteurLissage = vitesseUtilisateurMps >= 8
                    ? 0.78
                    : vitesseUtilisateurMps >= 3
                        ? 0.70
                        : 0.50;
                dernierCapUtilisateur = dateDernierCapFiable
                    ? lisserCap(
                        dernierCapUtilisateur,
                        capMesure,
                        facteurLissage
                    )
                    : capMesure;
                dateDernierCapFiable = Date.now();
            }

            var capReelRecent =
                utilisateurEnMouvement
                && Date.now() - dateDernierCapFiable < 5000
                && Number.isFinite(dernierCapUtilisateur);
            var capItineraire = navigationActive
                ? calculerCapItineraireDevant()
                : Number.NaN;
            var capAffichage = capReelRecent
                ? dernierCapUtilisateur
                : capItineraire;

            if (!Number.isFinite(capAffichage)) {
                capAffichage = dernierCapUtilisateur;
            }

            actualiserOrientationFlecheUtilisateur(capAffichage);

            if (
                suiviCarteActif
                && orientationAutomatiqueActive
            ) {
                orienterCarte(capAffichage);
            }

            document.getElementById(
                "latitude"
            ).value = latitudeUtilisateur;

            document.getElementById(
                "longitude"
            ).value = longitudeUtilisateur;

            document.getElementById(
                "position"
            ).innerHTML = "";

            actualiserStationsSelonPosition();
            calculerMeilleureStation();
            actualiserGuidageNavigation();
            verifierEcartItineraire();

            if (marqueurUtilisateur) {

                deplacerMarqueurUtilisateur(
                    latitudeUtilisateur,
                    longitudeUtilisateur
                );

            } else {

                var userIcon = L.divIcon({

                    html:
                        '<div class="gps-position-arrow"><span></span></div>',

                    className: "gps-user-marker",

                    iconSize: [46,46],
                    iconAnchor: [23,23]

                });

                marqueurUtilisateur =
                    L.marker(

                        [
                            latitudeUtilisateur,
                            longitudeUtilisateur
                        ],

                        {
                            icon: userIcon
                        }

                    )
                    .addTo(map)
                    .bindPopup(
                        "Vous etes ici"
                    );

                actualiserOrientationFlecheUtilisateur(capAffichage);

                if (premierCentrageUtilisateur) {

                    recentrerSurUtilisateur();
                    premierCentrageUtilisateur = false;

                }

            }

        },

        function(error) {

            console.log(
                "GPS refuse ou indisponible"
            );

        },

        {
            enableHighAccuracy: true,
            maximumAge: 0,
            timeout: 5000
        }

    );

}

