function calculerCapDeplacement(
    latitudeDepart,
    longitudeDepart,
    latitudeArrivee,
    longitudeArrivee
) {

    var conversion = Math.PI / 180;
    var latitude1 = latitudeDepart * conversion;
    var latitude2 = latitudeArrivee * conversion;
    var differenceLongitude = (
        longitudeArrivee - longitudeDepart
    ) * conversion;
    var y = Math.sin(differenceLongitude)
        * Math.cos(latitude2);
    var x = Math.cos(latitude1)
        * Math.sin(latitude2)
        - Math.sin(latitude1)
        * Math.cos(latitude2)
        * Math.cos(differenceLongitude);

    return (
        Math.atan2(y, x) / conversion + 360
    ) % 360;

}

function lisserCap(capPrecedent, nouveauCap, facteur) {

    if (!Number.isFinite(nouveauCap)) {
        return capPrecedent;
    }

    if (!Number.isFinite(capPrecedent)) {
        return (nouveauCap + 360) % 360;
    }

    var difference = (
        (nouveauCap - capPrecedent + 540) % 360
    ) - 180;

    return (
        capPrecedent + difference * facteur + 360
    ) % 360;

}

function calculerPointDevant(
    latitude,
    longitude,
    cap,
    distanceMetres
) {

    var rayonTerre = 6371000;
    var conversion = Math.PI / 180;
    var latitudeDepart = latitude * conversion;
    var longitudeDepart = longitude * conversion;
    var capRadians = cap * conversion;
    var distanceAngulaire = distanceMetres / rayonTerre;
    var latitudeCible = Math.asin(
        Math.sin(latitudeDepart) * Math.cos(distanceAngulaire)
        + Math.cos(latitudeDepart) * Math.sin(distanceAngulaire)
        * Math.cos(capRadians)
    );
    var longitudeCible = longitudeDepart + Math.atan2(
        Math.sin(capRadians) * Math.sin(distanceAngulaire)
        * Math.cos(latitudeDepart),
        Math.cos(distanceAngulaire)
        - Math.sin(latitudeDepart) * Math.sin(latitudeCible)
    );

    return {
        latitude: latitudeCible / conversion,
        longitude: longitudeCible / conversion
    };

}

function orienterCarte(capCible) {

    if (
        !orientationAutomatiqueActive
        ||
        !Number.isFinite(capCible)
        || typeof map.setBearing !== "function"
    ) {
        return;
    }

    if (animationOrientationCarte) {
        cancelAnimationFrame(animationOrientationCarte);
    }

    // leaflet-rotate attend la rotation visuelle de la carte, inverse du cap GPS.
    capCarte = (360 - capCible) % 360;
    map.setBearing(capCarte);
    animationOrientationCarte = null;
    actualiserOrientationFlecheUtilisateur(capCible);

}

function actualiserOrientationFlecheUtilisateur(capCible) {

    if (Number.isFinite(capCible)) {
        capFlecheUtilisateur = capCible;
    }

    if (!marqueurUtilisateur) {
        return;
    }

    var elementMarqueur = marqueurUtilisateur.getElement();
    var fleche = elementMarqueur
        ? elementMarqueur.querySelector(".gps-position-arrow")
        : null;

    if (!fleche) {
        return;
    }

    var rotation = suiviCarteActif && orientationAutomatiqueActive
        ? 0
        : (
            capFlecheUtilisateur + capCarte + 540
        ) % 360 - 180;
    fleche.style.transform = "rotate(" + rotation + "deg)";

}

function actualiserBoutonSuiviCarte() {

    if (!boutonSuiviCarte) {
        return;
    }

    boutonSuiviCarte.classList.toggle(
        "active",
        suiviCarteActif && orientationAutomatiqueActive
