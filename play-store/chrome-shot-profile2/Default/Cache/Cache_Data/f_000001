function stationEstFavorite(stationId) {

    return lireFavoris().some(
        function(favori) {

            return favori.id === stationId;

        }
    );

}

function retirerFavori(stationId) {

    var favoris = lireFavoris().filter(
        function(favori) {

            return favori.id !== stationId;

        }
    );

    enregistrerFavoris(favoris);
    actualiserBoutonsFavoris();

}

function changerFavori(station) {

    var favoris = lireFavoris();
    var indexFavori = favoris.findIndex(
        function(favori) {

            return favori.id === station.id;

        }
    );

    if (indexFavori >= 0) {

        favoris.splice(
            indexFavori,
            1
        );

    } else {

        if (favoris.length >= nombreMaximumFavorisActuel()) {

            alert(
                "Le compte gratuit permet d'ajouter 3 stations maximum en favoris."
            );

            return;

        }

        favoris.push(station);

    }

    enregistrerFavoris(favoris);
    actualiserBoutonsFavoris();

}

