function positionStationSurRoute(station, coordonnees) {

    if (!coordonnees || coordonnees.length < 2) {
        return null;
    }

    var distanceCumuleeKm = 0;
    var meilleur = null;

    for (var index = 0; index < coordonnees.length - 1; index += 1) {
        var depart = coordonnees[index];
        var arrivee = coordonnees[index + 1];
        var latitudeReference = station.latitude * Math.PI / 180;
        var conversionLongitude = 111320 * Math.cos(latitudeReference);
        var conversionLatitude = 110540;
        var x1 = (depart[0] - station.longitude) * conversionLongitude;
        var y1 = (depart[1] - station.latitude) * conversionLatitude;
        var x2 = (arrivee[0] - station.longitude) * conversionLongitude;
        var y2 = (arrivee[1] - station.latitude) * conversionLatitude;
        var dx = x2 - x1;
        var dy = y2 - y1;
        var longueurCarree = dx * dx + dy * dy;
        var progression = longueurCarree === 0
            ? 0
            : Math.max(0, Math.min(1, -(x1 * dx + y1 * dy) / longueurCarree));
        var xProche = x1 + progression * dx;
        var yProche = y1 + progression * dy;
        var ecartMetres = Math.hypot(xProche, yProche);
        var longueurSegmentKm = distanceDeplacementKm(
            depart[1],
            depart[0],
            arrivee[1],
            arrivee[0]
        );
        var distanceRouteKm =
            distanceCumuleeKm + longueurSegmentKm * progression;

        if (!meilleur || ecartMetres < meilleur.ecartMetres) {
            meilleur = {
                station: station,
                ecartMetres: ecartMetres,
                distanceRouteKm: distanceRouteKm
            };
        }

        distanceCumuleeKm += longueurSegmentKm;
    }

    return meilleur;

}

function stationProbablementSurAutoroute(station) {

    var texte = normaliserNomEnseigne(
        [
            station.enseigne,
            station.adresse,
            station.ville
        ].filter(Boolean).join(" ")
    );

    return /\b(a ?[0-9]{1,3}|autoroute|aire|service)\b/.test(texte);

}

function coutDetourStation(position, consommation) {

    var stationAutoroute = stationProbablementSurAutoroute(position.station);
    var kilometresDetour = position.ecartMetres * 2 / 1000;
    var coutCarburantDetour =
        kilometresDetour * consommation / 100 * position.station.prix;
    var penaliteSortieAutoroute = stationAutoroute || position.ecartMetres <= 800
        ? 0
        : position.ecartMetres <= 1300
            ? 1.50
            : 3.00;

    return coutCarburantDetour + penaliteSortieAutoroute;

}

function enrichirRentabiliteArret(position, prixReference, litres, consommation) {

    var economieBrute = Math.max(
        0,
        (prixReference - position.station.prix) * litres
    );
    var coutDetour = coutDetourStation(position, consommation);

    return Object.assign({}, position, {
        economieBrute: economieBrute,
        coutDetour: coutDetour,
        economieNette: economieBrute - coutDetour
    });

}

function proposerRavitaillementTrajetPremium(route) {

    var element = document.getElementById("navigation-refuel");

    if (!element) {
        return;
    }

    if (!comptePremiumActif() || !route || !route.geometry) {
        element.hidden = true;
        element.textContent = "";
        return;
    }

    var vehicule = vehiculeActif();
    var reservoir = Number(vehicule && vehicule.reservoir);
    var consommation = Number(vehicule && vehicule.conso);
    var jauge = Number(vehicule && vehicule.jauge);

    if (!reservoir || !consommation) {
        element.hidden = false;
        element.textContent =
            "Renseignez votre v\u00e9hicule pour calculer les ravitaillements du trajet.";
        return;
    }

    jauge = Math.max(0, Math.min(100, Number.isFinite(jauge) ? jauge : 50));
    var autonomieKm = reservoir * jauge / 100 / consommation * 100;
    var distanceTrajetKm = route.distance / 1000;

    var litresACompleter = reservoir * (100 - jauge) / 100;
    var prixReference = stationNavigationActive && stationNavigationActive.prix
        ? stationNavigationActive.prix
        : stationsEconomie
            .filter(function(station) {
                return station.prix > 0 && station.prix !== 9.999;
            })
            .reduce(function(total, station, index, liste) {
                return total + station.prix / liste.length;
            }, 0);

    var positionsStations = stationsEconomie
        .filter(function(station) {
            return station.prix > 0 && station.prix !== 9.999;
        })
        .map(function(station) {
            return positionStationSurRoute(
                station,
                route.geometry.coordinates
            );
        })
        .filter(function(position) {
            return position
                && position.ecartMetres <= 1800
                && position.distanceRouteKm > 1
                && position.distanceRouteKm < distanceTrajetKm - 1;
        })
        .map(function(position) {
            return enrichirRentabiliteArret(
                position,
                prixReference,
                Math.max(8, litresACompleter),
                consommation
            );
        });

    var arretOpportuniste = positionsStations
        .filter(function(position) {
            return position.distanceRouteKm <= Math.min(
                    distanceTrajetKm - 1,
                    autonomieKm * 0.85
                )
                && position.economieNette >= 2
                && (
                    position.ecartMetres <= 900
                    || stationProbablementSurAutoroute(position.station)
                    || position.economieNette >= 4
                );
        })
        .sort(function(a, b) {
            return b.economieNette - a.economieNette
                || a.station.prix - b.station.prix;
        })[0];

    var arrets = [];
    var distanceCouverte = Math.max(0, autonomieKm * 0.75);

    while (
        distanceCouverte < distanceTrajetKm
        && arrets.length < 3
    ) {
        var fenetreDebut = Math.max(0, distanceCouverte - 18);
        var fenetreFin = Math.min(distanceTrajetKm, distanceCouverte + 18);
        var candidat = positionsStations
            .filter(function(position) {
                return position.distanceRouteKm >= fenetreDebut
                    && position.distanceRouteKm <= fenetreFin
                    && !arrets.some(function(arret) {
                        return memeStation(arret.station, position.station);
                    });
            })
            .sort(function(a, b) {
                return b.economieNette - a.economieNette
                    || a.station.prix - b.station.prix
                    || a.ecartMetres - b.ecartMetres;
            })[0];

        if (!candidat) {
            break;
        }

        arrets.push(candidat);
        distanceCouverte = candidat.distanceRouteKm + autonomieKm * 0.75;
    }

    element.hidden = false;

    if (arretOpportuniste && !arrets.some(function(arret) {
        return memeStation(arret.station, arretOpportuniste.station);
    })) {
        arrets.unshift(arretOpportuniste);
    }

    if (distanceTrajetKm <= autonomieKm * 0.85 && !arrets.length) {
        element.innerHTML =
            "<strong>Ravitaillement :</strong> autonomie suffisante sur ce trajet.";
        return;
    }

    if (!arrets.length) {
        element.innerHTML =
            "<strong>Ravitaillement :</strong> aucune station pertinente charg\u00e9e sur ce trajet.";
        return;
    }

    element.innerHTML =
        "<strong>Ravitaillement conseill\u00e9 :</strong> "
        + arrets.map(
            function(arret) {
                return echapperHtml(
                    (arret.station.enseigne || "Station")
                    + (arret.station.ville ? " \u00e0 " + arret.station.ville : "")
                    + " vers "
                    + arret.distanceRouteKm.toLocaleString(
                        "fr-FR",
                        {
                            maximumFractionDigits: 0
                        }
                    )
                    + " km"
                    + (
                        arret.economieNette >= 2
                            ? " (gain net env. "
                                + arret.economieNette.toLocaleString(
                                    "fr-FR",
                                    {
                                        minimumFractionDigits: 2,
                                        maximumFractionDigits: 2
                                    }
                                )
                                + " \u20ac)"
                            : ""
                    )
                );
            }
        ).join(" puis ");

}

function dessinerItineraire(coordonnees, afficherApercu) {

    if (itineraireLayer) {

        map.removeLayer(itineraireLayer);

    }

    itineraireLayer = L.geoJSON(
        {
            type: "Feature",
            geometry: {
                type: "LineString",
                coordinates: coordonnees
            }
        },
        {
            style: {
                color: "#149f38",
                weight: 6,
                opacity: 0.92
            }
        }
    ).addTo(map);

    if (afficherApercu) {
        suiviCarteActif = false;
        orientationAutomatiqueActive = false;
        actualiserBoutonSuiviCarte();
        capCarte = 0;
        map.setBearing(0);
        map.setPitch(inclinaisonCarteGps);
        map.fitBounds(
            itineraireLayer.getBounds(),
            {
                padding: [60, 60]
            }
        );
    }

}

function formaterDistanceNavigation(distanceMetres) {

    if (distanceMetres < 1000) {
        return Math.max(
            10,
            Math.round(distanceMetres / 10) * 10
        ) + " m";
    }

    return (distanceMetres / 1000).toLocaleString(
        "fr-FR",
        { maximumFractionDigits: 1 }
    ) + " km";

}

function symboleManeuvre(maneuvre) {

    var modificateur = maneuvre.modifier || "straight";

    if (modificateur.includes("left")) {
        return modificateur === "slight left" ? "\u2196" : "\u21b0";
    }
    if (modificateur.includes("right")) {
        return modificateur === "slight right" ? "\u2197" : "\u21b1";
    }
    if (modificateur === "uturn") {
        return "\u21b6";
    }
    return "\u2191";

}

function texteManeuvre(etape) {

    var maneuvre = etape.maneuver || {};
    var voie = etape.name ? " sur " + etape.name : "";
    var modificateur = maneuvre.modifier || "straight";

    if (maneuvre.type === "arrive") {
        return "Vous \u00eates arriv\u00e9";
    }
    if (maneuvre.type === "roundabout" || maneuvre.type === "rotary") {
        return "Au rond-point, prenez la sortie "
            + (maneuvre.exit || "indiqu\u00e9e")
            + voie;
    }
    if (modificateur.includes("left")) {
        return "Tournez \u00e0 gauche" + voie;
    }
    if (modificateur.includes("right")) {
        return "Tournez \u00e0 droite" + voie;
    }
    if (modificateur === "uturn") {
        return "Faites demi-tour" + voie;
    }
    return "Continuez tout droit" + voie;

}

function actualiserGuidageNavigation() {

    if (relanceItineraireEnCours) {
        document.getElementById("navigation-arrow").textContent = "\u2191";
        document.getElementById("navigation-instruction").textContent =
            "Calcul en cours...";
        document.getElementById("navigation-distance").textContent = "";
        return;
    }

    if (
        !navigationActive
        || !etapesNavigation.length
        || latitudeUtilisateur === null
        || longitudeUtilisateur === null
    ) {
        return;
    }

    var etape = etapesNavigation[indexEtapeNavigation];
    var positionManeuvre = etape.maneuver.location;
    var distanceManeuvre = distanceDeplacementKm(
        latitudeUtilisateur,
        longitudeUtilisateur,
        positionManeuvre[1],
        positionManeuvre[0]
    ) * 1000;

    while (
        distanceManeuvre < 35
        && indexEtapeNavigation < etapesNavigation.length - 1
    ) {
        indexEtapeNavigation += 1;
        etape = etapesNavigation[indexEtapeNavigation];
        positionManeuvre = etape.maneuver.location;
        distanceManeuvre = distanceDeplacementKm(
            latitudeUtilisateur,
            longitudeUtilisateur,
            positionManeuvre[1],
            positionManeuvre[0]
        ) * 1000;
    }

    var dureeRestante = etapesNavigation
        .slice(indexEtapeNavigation)
        .reduce(
            function(total, prochaineEtape) {
                return total + (prochaineEtape.duration || 0);
            },
            0
        );

    document.getElementById("navigation-arrow").textContent =
        symboleManeuvre(etape.maneuver || {});
    document.getElementById("navigation-instruction").textContent =
        texteManeuvre(etape);
    document.getElementById("navigation-distance").textContent =
        formaterDistanceNavigation(distanceManeuvre)
        + " \u00b7 "
        + formaterDuree(dureeRestante / 60)
        + " restantes";

}

function distanceItineraireMetres() {

    if (!coordonneesRouteNavigation.length) {
        return Number.POSITIVE_INFINITY;
    }

    var conversionLongitude =
        111320 * Math.cos(latitudeUtilisateur * Math.PI / 180);
    var conversionLatitude = 110540;
    var distanceMinimum = Number.POSITIVE_INFINITY;

    for (var index = 0; index < coordonneesRouteNavigation.length - 1; index += 1) {
        var depart = coordonneesRouteNavigation[index];
        var arrivee = coordonneesRouteNavigation[index + 1];
        var x1 = (depart[0] - longitudeUtilisateur) * conversionLongitude;
        var y1 = (depart[1] - latitudeUtilisateur) * conversionLatitude;
        var x2 = (arrivee[0] - longitudeUtilisateur) * conversionLongitude;
        var y2 = (arrivee[1] - latitudeUtilisateur) * conversionLatitude;
        var dx = x2 - x1;
        var dy = y2 - y1;
        var longueurCarree = dx * dx + dy * dy;
        var progression = longueurCarree === 0
            ? 0
            : Math.max(
                0,
                Math.min(1, -(x1 * dx + y1 * dy) / longueurCarree)
            );
        var xProche = x1 + progression * dx;
        var yProche = y1 + progression * dy;
        distanceMinimum = Math.min(
            distanceMinimum,
            Math.hypot(xProche, yProche)
        );
    }

    return distanceMinimum;

}

function verifierEcartItineraire() {

    if (
        !navigationActive
        || !destinationNavigation
        || relanceItineraireEnCours
        || latitudeUtilisateur === null
        || longitudeUtilisateur === null
    ) {
        return;
    }

    var distanceDestination = distanceDeplacementKm(
        latitudeUtilisateur,
        longitudeUtilisateur,
        destinationNavigation.latitude,
        destinationNavigation.longitude
    ) * 1000;

    if (distanceDestination < 40) {
        reinitialiserDetectionEcart();
        return;
    }

    var seuilEcart = Math.max(75, precisionUtilisateur * 1.5);
    if (distanceItineraireMetres() > seuilEcart) {
        positionsHorsItineraire += 1;

        if (!debutEcartItineraire) {
            debutEcartItineraire = Date.now();
            minuteurRecalculItineraire = setTimeout(
                function() {
                    minuteurRecalculItineraire = null;
                    verifierEcartItineraire();
                },
                delaiRecalculItineraireMs
            );
        }
    } else {
        reinitialiserDetectionEcart();
        return;
    }

    if (
        Date.now() - debutEcartItineraire
            < delaiRecalculItineraireMs
        || Date.now() - derniereRelanceItineraire
            < delaiRecalculItineraireMs
    ) {
        return;
    }

    reinitialiserDetectionEcart();
    derniereRelanceItineraire = Date.now();
    relanceItineraireEnCours = true;
    tracerItineraire(
        destinationNavigation.latitude,
        destinationNavigation.longitude,
        true
    ).finally(
        function() {
            relanceItineraireEnCours = false;
        }
    );

}

window.demarrerNavigation = async function() {

    if (!routeNavigation) {
        return;
    }

    if (!Number.isFinite(derniereEconomieEstimee)) {
        calculerMeilleureStation();
    }
    economieEstimeeFigee = Number.isFinite(derniereEconomieEstimee)
        ? derniereEconomieEstimee
        : null;
    navigationActive = true;
    suiviCarteActif = true;
    orientationAutomatiqueActive = true;
    actualiserBoutonSuiviCarte();
    document.getElementById("navigation-panel").hidden = false;

    var bouton = document.getElementById("economy-route-button");
    if (bouton) {
        bouton.textContent = "Arr\u00eater";
        bouton.classList.add("stop");
        bouton.onclick = arreterNavigation;
    }

    recentrerSurUtilisateur();
    actualiserGuidageNavigation();

    if (destinationNavigation && !relanceItineraireEnCours) {
        relanceItineraireEnCours = true;
        try {
            await tracerItineraire(
                destinationNavigation.latitude,
                destinationNavigation.longitude,
                true
            );
        } finally {
            relanceItineraireEnCours = false;
        }
    }

};

window.arreterNavigation = function() {

    navigationActive = false;
    economieEstimeeFigee = null;
    stationNavigationActive = null;
    propositionStationPlusRentable = null;
    cacherPopupStationPlusRentable();
    proposerRavitaillementTrajetPremium(null);
    reinitialiserDetectionEcart();
    document.getElementById("navigation-panel").hidden = true;

    var bouton = document.getElementById("economy-route-button");
    if (bouton && routeNavigation) {
        bouton.textContent = "D\u00e9marrer";
        bouton.classList.remove("stop");
        bouton.onclick = demarrerNavigation;
    }

    calculerMeilleureStation();

}

async function tracerItineraire(
    latitudeStation,
    longitudeStation,
    maintenirNavigation,
    stationCible,
    economieCible
) {

    maintenirNavigation = Boolean(maintenirNavigation);
    stationCible = stationCible
        || trouverStationParCoordonnees(latitudeStation, longitudeStation);

    if (
        latitudeUtilisateur === null
        ||
        longitudeUtilisateur === null
    ) {

        afficherInfoItineraire(
            "Position GPS en attente pour calculer l'itineraire."
        );
        demarrerGeolocalisation();
        return;

    }

    afficherInfoItineraire(
        maintenirNavigation
            ? "Adaptation de l'itineraire..."
            : "Calcul de l'itineraire..."
    );

    if (maintenirNavigation) {
        navigationActive = true;
        document.getElementById("navigation-panel").hidden = false;
        document.getElementById("navigation-instruction").textContent =
            "Calcul en cours...";
        document.getElementById("navigation-distance").textContent = "";
    } else {
        arreterNavigation();
        routeNavigation = null;
        etapesNavigation = [];
        indexEtapeNavigation = 0;
    }

    var boutonItineraire = document.getElementById(
        "economy-route-button"
    );
    if (boutonItineraire && !maintenirNavigation) {
        boutonItineraire.textContent = "Calcul...";
        boutonItineraire.classList.remove("stop");
        boutonItineraire.disabled = true;
    }

    var capRecent =
        utilisateurEnMouvement
        && Date.now() - dateDernierCapFiable < 10000
        && Number.isFinite(dernierCapUtilisateur);
    var url =
        "https://router.project-osrm.org/route/v1/driving/"
        + longitudeUtilisateur
        + ","
        + latitudeUtilisateur
        + ";"
        + longitudeStation
        + ","
        + latitudeStation
        + "?overview=full&geometries=geojson&steps=true&continue_straight=true";

    if (capRecent) {
        url += "&bearings="
            + Math.round(dernierCapUtilisateur)
            + ",45;";
    }

    try {

        var response = await fetch(url);

        if (!response.ok) {

            throw new Error("route indisponible");

        }

        var data = await response.json();
        var route = data.routes && data.routes[0];

        if (!route) {

            throw new Error("route introuvable");

        }

        dessinerItineraire(
            route.geometry.coordinates,
            !maintenirNavigation
        );

        routeNavigation = route;
        stationNavigationActive = stationCible;
        if (Number.isFinite(economieCible)) {
            economieEstimeeFigee = economieCible;
        }
        destinationNavigation = {
            latitude: latitudeStation,
            longitude: longitudeStation,
            stationId: stationCible ? stationCible.id : "",
            enseigne: stationCible ? stationCible.enseigne : "",
            ville: stationCible ? stationCible.ville : ""
        };
        coordonneesRouteNavigation = route.geometry.coordinates;
        proposerRavitaillementTrajetPremium(route);
        etapesNavigation = (route.legs || []).reduce(
            function(toutesLesEtapes, trajet) {
                return toutesLesEtapes.concat(trajet.steps || []);
            },
            []
        );
        indexEtapeNavigation = 0;

        var distanceKm = (
            route.distance / 1000
        ).toFixed(1);
        var dureeMinutes = route.duration / 60;

        afficherInfoItineraire(
            distanceKm
            + " km - "
            + formaterDuree(dureeMinutes)
        );

        if (boutonItineraire && maintenirNavigation) {
            boutonItineraire.disabled = false;
            boutonItineraire.textContent = "Arr\u00eater";
            boutonItineraire.classList.add("stop");
            boutonItineraire.onclick = arreterNavigation;
        } else if (boutonItineraire) {
            boutonItineraire.disabled = false;
            boutonItineraire.textContent = "D\u00e9marrer";
            boutonItineraire.classList.remove("stop");
            boutonItineraire.onclick = demarrerNavigation;
            boutonItineraire.hidden = false;
        }

        if (maintenirNavigation) {
            suiviCarteActif = true;
            actualiserBoutonSuiviCarte();
            recentrerSurUtilisateur();
            actualiserGuidageNavigation();
        }

        map.closePopup();

    } catch (erreur) {

        if (boutonItineraire && !maintenirNavigation) {
            boutonItineraire.disabled = false;
            boutonItineraire.textContent = "Itin\u00e9raire";
            boutonItineraire.classList.remove("stop");
            boutonItineraire.onclick = function() {
                tracerItineraire(
                    latitudeStation,
                    longitudeStation
                );
            };
        }

        afficherInfoItineraire(
            maintenirNavigation
                ? "Guidage conserv\u00e9, nouveau calcul indisponible."
                : "Impossible de calculer l'itineraire pour le moment."
        );

        if (maintenirNavigation) {
            actualiserGuidageNavigation();
        }

    }

}
