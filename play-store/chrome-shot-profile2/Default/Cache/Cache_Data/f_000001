function calculerRentabiliteStations(
    stationsDisponibles,
    latitudeCalcul,
    longitudeCalcul,
    reservoir,
    consommation,
    litresACompleter
) {

    var stationsCalculees = stationsDisponibles.map(
        function(station) {

            var distance = distanceDeplacementKm(
                latitudeCalcul,
                longitudeCalcul,
                station.latitude,
                station.longitude
            );
            var carburantTrajet =
                distance * 2 * consommation / 100;

            return Object.assign({}, station, {
                distanceCalculee: distance,
                carburantTrajet: carburantTrajet
            });

        }
    );

    stationsCalculees.forEach(
        function(station) {

            station.coutTotal =
                litresACompleter * station.prix
                + station.carburantTrajet * station.prix;

        }
    );

    if (!comptePremiumActif()) {
        var prixMoyen = stationsDisponibles.reduce(
            function(total, station) {
                return total + station.prix;
            },
            0
        ) / stationsDisponibles.length;
        var coutPleinReference = litresACompleter * prixMoyen;

        return {
            stationsCalculees: stationsCalculees.map(
                function(station) {
                    return Object.assign({}, station, {
                        coutTotal:
                            litresACompleter * station.prix
                            + station.carburantTrajet * prixMoyen
                    });
                }
            ),
            coutReference: coutPleinReference,
            libelleReference:
                " par rapport au prix moyen local"
        };
    }

    var coutReferenceParStation = stationsCalculees.map(
        function(stationReference) {
            return {
                station: stationReference,
                cout:
                    litresACompleter * stationReference.prix
                    + stationReference.carburantTrajet
                        * stationReference.prix
            };
        }
    );

    stationsCalculees.forEach(
        function(station) {

            var meilleureReference = coutReferenceParStation
                .filter(
                    function(reference) {
                        return reference.station.id !== station.id;
                    }
                )
                .reduce(
                    function(meilleure, reference) {
                        return !meilleure || reference.cout < meilleure.cout
                            ? reference
                            : meilleure;
                    },
                    null
                );

            station.economieComparee = meilleureReference
                ? Math.max(
                    0,
                    meilleureReference.cout - station.coutTotal
                )
                : 0;

        }
    );

    return {
        stationsCalculees: stationsCalculees,
        coutReference: null,
        libelleReference:
            " par rapport \u00e0 la 2e station la plus rentable"
    };

}

