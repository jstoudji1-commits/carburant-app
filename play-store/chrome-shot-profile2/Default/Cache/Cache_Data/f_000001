function normaliserNomEnseigne(nom) {
    return String(nom || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, " ")
        .trim();
}

function echapperHtml(valeur) {
    return String(valeur || "").replace(/[&<>"']/g, function(caractere) {
        return {
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            "\"": "&quot;",
            "'": "&#039;"
        }[caractere];
    });
}

function creerLogoEnseigne(nom, contexte) {
    var nomNormalise = normaliserNomEnseigne(nom);
    var logo = logosEnseignes.find(function(definition) {
        return definition.motifs.some(function(motif) {
            return definition.exact
                ? nomNormalise === motif
                : nomNormalise.indexOf(motif) !== -1;
        });
    });
    var libelle = nom || "Station-service";

    if (logo) {
        var fichier = contexte === "carte" && logo.fichierCarte
            ? logo.fichierCarte
            : logo.fichier;
        var classe = contexte === "carte"
            ? logo.classeCarte
            : logo.classePopup;

        return '<span class="enseigne-logo'
            + (classe ? ' ' + classe : '')
            + '"><img src="/static/brand-logos/'
            + fichier
            + '" alt="Logo '
            + echapperHtml(libelle)
            + '"></span>';
    }

    return '<span class="enseigne-logo enseigne-logo-optiplein" title="'
        + echapperHtml(libelle)
        + '"><img src="/static/favicon.png" alt="Station sans logo identifi&eacute;"></span>';
}

