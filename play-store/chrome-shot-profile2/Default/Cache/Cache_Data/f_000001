async function requeteCompte(chemin, options) {

    var entetes = {
        "Content-Type": "application/json"
    };
    var jeton = jetonCompte();

    if (jeton) {
        entetes.Authorization = "Bearer " + jeton;
    }

    var reponse = await fetch(
        chemin,
        Object.assign(
            {
                headers: entetes
            },
            options || {}
        )
    );
    var resultat = await reponse.json().catch(
        function() {
            return {};
        }
    );

    if (!reponse.ok) {
        throw new Error(
            resultat.detail || "Action impossible pour le moment."
        );
    }

    return resultat;

}

function identifiantsCompteDepuisFormulaire() {

    var email = (
        document.getElementById("account-email").value || ""
    ).trim();
    var motDePasse = document.getElementById("account-password").value || "";

    if (!email || !motDePasse) {
        throw new Error("Renseignez l'e-mail et le mot de passe.");
    }

    if (motDePasse.length < 8) {
        throw new Error("Le mot de passe doit contenir au moins 8 caract\u00e8res.");
    }

    return {
        email: email,
        mot_de_passe: motDePasse
    };

}

async function finaliserConnexionCompte(resultat, sauvegarderLocal) {

    localStorage.setItem(compteTokenCle, resultat.token);
    localStorage.setItem(compteEmailCle, resultat.email);

    if (sauvegarderLocal) {
        await sauvegarderCompteMaintenant();
    } else {
        appliquerDonneesCompte(resultat.donnees || {});
    }

    actualiserInterfaceCompte();

}

window.creerCompteOptiPlein = async function(event) {

    if (event) {
        event.preventDefault();
        event.stopPropagation();
    }

    try {
        definirStatutCompte("Cr\u00e9ation du compte...", "");
        var resultat = await requeteCompte(
            "/api/compte/inscription",
            {
                method: "POST",
                body: JSON.stringify(
                    identifiantsCompteDepuisFormulaire()
                )
            }
        );
        await finaliserConnexionCompte(resultat, true);
        definirStatutCompte(
            "Compte "
            + (comptePremiumActif() ? "Premium" : "Gratuit")
            + " cr\u00e9\u00e9 et donn\u00e9es sauvegard\u00e9es.",
            "success"
        );
    } catch (erreur) {
        definirStatutCompte(erreur.message, "error");
    }

};

window.connecterCompteOptiPlein = async function(event) {

    if (event) {
        event.preventDefault();
        event.stopPropagation();
    }

    try {
        definirStatutCompte("Connexion...", "");
        var resultat = await requeteCompte(
            "/api/compte/connexion",
            {
                method: "POST",
                body: JSON.stringify(
                    identifiantsCompteDepuisFormulaire()
                )
            }
        );
        await finaliserConnexionCompte(resultat, false);
        definirStatutCompte("Compte connect\u00e9 et donn\u00e9es restaur\u00e9es.", "success");
    } catch (erreur) {
        definirStatutCompte(erreur.message, "error");
    }

};

window.deconnecterCompteOptiPlein = function(event) {

    if (event) {
        event.preventDefault();
        event.stopPropagation();
    }

    localStorage.removeItem(compteTokenCle);
    localStorage.removeItem(compteEmailCle);
    actualiserInterfaceCompte();

};

async function sauvegarderCompteMaintenant() {

    if (!compteUtilisateurConnecte()) {
        return;
    }

    await requeteCompte(
        "/api/compte/sauvegarde",
        {
            method: "POST",
            body: JSON.stringify({
                donnees: donneesCompteLocales()
            })
        }
    );

    definirStatutCompte(
        "Sauvegard\u00e9 \u00e0 l'instant.",
        "success"
    );

}

function programmerSauvegardeCompte() {

    if (
        applicationDonneesCompteEnCours
        || !compteUtilisateurConnecte()
    ) {
        return;
    }

    window.clearTimeout(sauvegardeCompteTimer);
    sauvegardeCompteTimer = window.setTimeout(
        function() {
            sauvegarderCompteMaintenant().catch(
                function(erreur) {
                    definirStatutCompte(erreur.message, "error");
                }
            );
        },
        700
    );

}

async function restaurerSessionCompte() {

    actualiserInterfaceCompte();

    if (!compteUtilisateurConnecte()) {
        return;
    }

    try {
        var resultat = await requeteCompte(
            "/api/compte/donnees",
            {
                method: "GET"
            }
        );
        appliquerDonneesCompte(resultat.donnees || {});
        definirStatutCompte(
            "Donn\u00e9es du compte synchronis\u00e9es.",
            "success"
        );
    } catch (erreur) {
        localStorage.removeItem(compteTokenCle);
        actualiserInterfaceCompte();
        definirStatutCompte(
            erreur.message,
            "error"
        );
    }

}

