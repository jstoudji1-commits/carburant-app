function calculerCapItineraireDevant() {

    if (
        !navigationActive
        || coordonneesRouteNavigation.length < 2
        || latitudeUtilisateur === null
        || longitudeUtilisateur === null
    ) {
        return Number.NaN;
    }

    var conversionLongitude =
        111320 * Math.cos(latitudeUtilisateur * Math.PI / 180);
    var conversionLatitude = 110540;
    var meilleurSegment = null;

    for (
        var index = 0;
        index < coordonneesRouteNavigation.length - 1;
        index += 1
    ) {
        var depart = coordonneesRouteNavigation[index];
        var arrivee = coordonneesRouteNavigation[index + 1];
        var segmentX =
            (arrivee[0] - depart[0]) * conversionLongitude;
        var segmentY =
            (arrivee[1] - depart[1]) * conversionLatitude;
        var positionX =
            (longitudeUtilisateur - depart[0]) * conversionLongitude;
        var positionY =
            (latitudeUtilisateur - depart[1]) * conversionLatitude;
        var longueurCarree =
            segmentX * segmentX + segmentY * segmentY;
        var progression = longueurCarree > 0
            ? Math.max(
                0,
                Math.min(
                    1,
                    (
                        positionX * segmentX
                        + positionY * segmentY
                    ) / longueurCarree
                )
            )
            : 0;
        var ecartX = positionX - progression * segmentX;
        var ecartY = positionY - progression * segmentY;
        var distanceCarree = ecartX * ecartX + ecartY * ecartY;

        if (
            !meilleurSegment
            || distanceCarree < meilleurSegment.distanceCarree
        ) {
            meilleurSegment = {
                index: index,
                progression: progression,
                distanceCarree: distanceCarree,
                longitude:
                    depart[0]
                    + (arrivee[0] - depart[0]) * progression,
                latitude:
                    depart[1]
                    + (arrivee[1] - depart[1]) * progression
            };
        }
    }

    if (!meilleurSegment) {
        return Number.NaN;
    }

    var distanceAnticipation = Math.max(
        25,
        Math.min(70, vitesseUtilisateurMps * 3)
    );
    var longitudeCourante = meilleurSegment.longitude;
    var latitudeCourante = meilleurSegment.latitude;
    var indexSegment = meilleurSegment.index;
    var distanceRestante = distanceAnticipation;
    var cible = null;

    while (
        indexSegment < coordonneesRouteNavigation.length - 1
    ) {
        var finSegment =
            coordonneesRouteNavigation[indexSegment + 1];
        var longueurSegment = distanceDeplacementKm(
            latitudeCourante,
            longitudeCourante,
            finSegment[1],
            finSegment[0]
        ) * 1000;

        if (
            longueurSegment > 0
            && longueurSegment >= distanceRestante
        ) {
            var ratio = distanceRestante / longueurSegment;
            cible = {
                longitude:
                    longitudeCourante
                    + (finSegment[0] - longitudeCourante) * ratio,
                latitude:
                    latitudeCourante
                    + (finSegment[1] - latitudeCourante) * ratio
            };
            break;
        }

        distanceRestante -= longueurSegment;
        longitudeCourante = finSegment[0];
        latitudeCourante = finSegment[1];
        indexSegment += 1;
    }

    if (!cible) {
        var dernierPoint =
            coordonneesRouteNavigation[
                coordonneesRouteNavigation.length - 1
            ];
        cible = {
            longitude: dernierPoint[0],
            latitude: dernierPoint[1]
        };
    }

    if (
        distanceDeplacementKm(
            meilleurSegment.latitude,
            meilleurSegment.longitude,
            cible.latitude,
            cible.longitude
        ) < 0.003
    ) {
        return Number.NaN;
    }

    return calculerCapDeplacement(
        meilleurSegment.latitude,
        meilleurSegment.longitude,
        cible.latitude,
        cible.longitude
    );

}

