function creerAdaptateurMapLibre() {

    var cleMapTiler = window.OPTIPLEIN_MAPTILER_KEY || "";
    var styleCarte = cleMapTiler
        ? "https://api.maptiler.com/maps/streets-v2/style.json?key="
            + encodeURIComponent(cleMapTiler)
        : {
        version: 8,
        sources: {
            "carto-light": {
                type: "raster",
                tiles: [
                    "https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
                    "https://b.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
                    "https://c.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png",
                    "https://d.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png"
                ],
                tileSize: 256,
                attribution: "&copy; contributeurs OpenStreetMap"
            }
        },
        layers: [
            {
                id: "carto-light",
                type: "raster",
                source: "carto-light"
            }
        ]
    };

    function normaliserLatLng(position) {
        if (Array.isArray(position)) {
            return {
                lat: Number(position[0]),
                lng: Number(position[1])
            };
        }

        return {
            lat: Number(position.lat),
            lng: Number(position.lng)
        };
    }

    function normaliserBounds(bounds) {
        if (bounds && typeof bounds.toArray === "function") {
            return bounds.toArray();
        }

        return bounds;
    }

    function creerCarte(id, options) {
        var carteInterne = new maplibregl.Map({
            container: id,
            style: styleCarte,
            center: [2.4, 46.6],
            zoom: 6,
            bearing: options && Number.isFinite(options.bearing)
                ? options.bearing
                : 0,
            pitch: 58,
            attributionControl: false
        });
        carteInterne.addControl(
            new maplibregl.NavigationControl({
                visualizePitch: true
            }),
            "bottom-right"
        );

        var adaptateur = {
            _map: carteInterne,
            setView: function(position, zoom, optionsVue) {
                var point = normaliserLatLng(position);
                carteInterne.easeTo({
                    center: [point.lng, point.lat],
                    zoom: zoom,
                    duration: optionsVue && optionsVue.animate ? 450 : 0
                });
                return adaptateur;
            },
            panTo: function(position, optionsVue) {
                var point = normaliserLatLng(position);
                carteInterne.easeTo({
                    center: [point.lng, point.lat],
                    duration: optionsVue && optionsVue.animate ? 350 : 0
                });
                return adaptateur;
            },
            getZoom: function() {
                return carteInterne.getZoom();
            },
            zoomIn: function() {
                carteInterne.zoomIn();
                return adaptateur;
            },
            zoomOut: function() {
                carteInterne.zoomOut();
                return adaptateur;
            },
            setBearing: function(cap) {
                carteInterne.rotateTo(cap, {
                    duration: 0
                });
                return adaptateur;
            },
            getBearing: function() {
                return (carteInterne.getBearing() + 360) % 360;
            },
            setPitch: function(inclinaison) {
                carteInterne.easeTo({
                    pitch: inclinaison,
                    duration: 250
                });
                return adaptateur;
            },
            fitBounds: function(bounds, optionsVue) {
                var padding = optionsVue && optionsVue.padding
                    ? optionsVue.padding
                    : [40, 40];
                carteInterne.fitBounds(
                    normaliserBounds(bounds),
                    {
                        padding: Array.isArray(padding)
                            ? {
                                top: padding[0],
                                right: padding[1],
                                bottom: padding[0],
                                left: padding[1]
                            }
                            : padding,
                        pitch: 58,
                        duration: 450
                    }
                );
                return adaptateur;
            },
            removeLayer: function(couche) {
                if (couche && typeof couche.remove === "function") {
                    couche.remove();
                }
                return adaptateur;
            },
            closePopup: function() {
                document.querySelectorAll(".maplibregl-popup")
                    .forEach(function(popup) {
                        var bouton = popup.querySelector(
                            ".maplibregl-popup-close-button"
                        );
                        if (bouton) {
                            bouton.click();
                        }
                    });
                return adaptateur;
            },
            getContainer: function() {
                return carteInterne.getContainer();
            },
            on: function(evenement, rappel) {
                carteInterne.on(evenement, rappel);
                return adaptateur;
            }
        };

        return adaptateur;
    }

    function creerIcone(options) {
        return options || {};
    }

    function creerMarqueur(position, options) {
        var pointInitial = normaliserLatLng(position);
        var element = document.createElement("div");
        var icone = options && options.icon ? options.icon : {};
        element.className = icone.className || "";
        element.innerHTML = icone.html || "";

        if (icone.iconSize) {
            element.style.width = icone.iconSize[0] + "px";
            element.style.height = icone.iconSize[1] + "px";
        }

        var marqueurInterne = new maplibregl.Marker({
            element: element,
            anchor: "center"
        }).setLngLat([pointInitial.lng, pointInitial.lat]);
        var popupInterne = null;
        var carteCible = null;
        var evenements = {};

        var adaptateurMarqueur = {
            addTo: function(carte) {
                carteCible = carte;
                marqueurInterne.addTo(carte._map);
                return adaptateurMarqueur;
            },
            bindPopup: function(html) {
                popupInterne = new maplibregl.Popup({
                    offset: 24,
                    closeButton: true,
                    closeOnClick: true
                }).setHTML(html);
                popupInterne.on("open", function() {
                    (evenements.popupopen || []).forEach(
                        function(rappel) {
                            rappel();
                        }
                    );
                });
                marqueurInterne.setPopup(popupInterne);
                return adaptateurMarqueur;
            },
            on: function(evenement, rappel) {
                evenements[evenement] = evenements[evenement] || [];
                evenements[evenement].push(rappel);
                return adaptateurMarqueur;
            },
            getElement: function() {
                return marqueurInterne.getElement();
            },
            setLatLng: function(positionNouvelle) {
                var point = normaliserLatLng(positionNouvelle);
                marqueurInterne.setLngLat([point.lng, point.lat]);
                return adaptateurMarqueur;
            },
            getLatLng: function() {
                var point = marqueurInterne.getLngLat();
                return {
                    lat: point.lat,
                    lng: point.lng
                };
            },
            openPopup: function() {
                if (popupInterne && carteCible) {
                    popupInterne.setLngLat(marqueurInterne.getLngLat());
                    popupInterne.addTo(carteCible._map);
                }
                return adaptateurMarqueur;
            },
            remove: function() {
                marqueurInterne.remove();
            }
        };

        return adaptateurMarqueur;
    }

    function creerFeatureGroup(marqueurs) {
        return {
            getBounds: function() {
                var limites = new maplibregl.LngLatBounds();
                marqueurs.forEach(function(marqueur) {
                    var point = marqueur.getLatLng();
                    limites.extend([point.lng, point.lat]);
                });
                return limites;
            }
        };
    }

    function creerGeoJson(donnees, options) {
        var identifiant = "route-" + Date.now();
        var carteCible = null;
        var couche = {
            addTo: function(carte) {
                carteCible = carte;
                var couleur = options && options.style
                    ? options.style.color
                    : "#149f38";
                var epaisseur = options && options.style
                    ? options.style.weight
                    : 6;
                var opacite = options && options.style
                    ? options.style.opacity
                    : 0.92;

                function ajouter() {
                    if (carte._map.getSource(identifiant)) {
                        return;
                    }
                    carte._map.addSource(identifiant, {
                        type: "geojson",
                        data: donnees
                    });
                    carte._map.addLayer({
                        id: identifiant,
                        type: "line",
                        source: identifiant,
                        layout: {
                            "line-cap": "round",
                            "line-join": "round"
                        },
                        paint: {
                            "line-color": couleur,
                            "line-width": epaisseur,
                            "line-opacity": opacite
                        }
                    });
                }

                if (carte._map.isStyleLoaded()) {
                    ajouter();
                } else {
                    carte._map.once("load", ajouter);
                }

                return couche;
            },
            getBounds: function() {
                var limites = new maplibregl.LngLatBounds();
                donnees.geometry.coordinates.forEach(function(point) {
                    limites.extend(point);
                });
                return limites;
            },
            remove: function() {
                if (!carteCible) {
                    return;
                }
                if (carteCible._map.getLayer(identifiant)) {
                    carteCible._map.removeLayer(identifiant);
                }
                if (carteCible._map.getSource(identifiant)) {
                    carteCible._map.removeSource(identifiant);
                }
            }
        };

        return couche;
    }

    return {
        map: creerCarte,
        tileLayer: function() {
            return {
                addTo: function() {}
            };
        },
        divIcon: creerIcone,
        marker: creerMarqueur,
        featureGroup: creerFeatureGroup,
        geoJSON: creerGeoJson,
        Control: {
            extend: function(definition) {
                return function() {
                    this.addTo = function(carte) {
                        var element = definition.onAdd();
                        element.classList.add("maplibregl-ctrl");
                        carte._map.addControl(
                            {
                                onAdd: function() {
                                    return element;
                                },
                                onRemove: function() {
                                    element.remove();
                                }
                            },
                            definition.options && definition.options.position
                                ? definition.options.position
                                    .replace("bottomright", "bottom-right")
                                : "bottom-right"
                        );
                        return this;
                    };
                };
            }
        },
        DomUtil: {
            create: function(tag, classe, parent) {
                var element = document.createElement(tag);
                element.className = classe || "";
                if (parent) {
                    parent.appendChild(element);
                }
                return element;
            }
        },
        DomEvent: {
            disableClickPropagation: function(element) {
                element.addEventListener("click", function(event) {
                    event.stopPropagation();
                });
            },
            on: function(element, evenement, rappel) {
                element.addEventListener(evenement, rappel);
            }
        }
    };

}

